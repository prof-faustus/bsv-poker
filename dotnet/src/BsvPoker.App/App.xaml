<Application x:Class="BsvPoker.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- NO StartupUri: the main window is NOT auto-shown. App.OnStartup runs the wallet selector → password
         FIRST (sequential, with NOTHING behind them) and only THEN shows the main window. -->
    <Application.Resources>
        <SolidColorBrush x:Key="Bg" Color="#0D0D0D" />
        <SolidColorBrush x:Key="Fg" Color="#EEEEEE" />
        <SolidColorBrush x:Key="Accent" Color="#2E7D32" />
        <SolidColorBrush x:Key="Warn" Color="#C77800" />

        <!-- CONTRAST GUARANTEE (the principal's absolute rule: NEVER same-colour text on same-colour background).
             The dark theme sets a light Foreground on the whole window, so ANY input left with its default WHITE
             background would render light-text-on-white = invisible. These implicit styles give EVERY text input
             across the ENTIRE app (main window AND every dialog) an explicit dark background with light text, so
             there is never a white-on-white (or any same-colour) field anywhere. -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Foreground" Value="#ECECEC" />
            <Setter Property="CaretBrush" Value="#ECECEC" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="Padding" Value="4,3,4,3" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Foreground" Value="#ECECEC" />
            <Setter Property="CaretBrush" Value="#ECECEC" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="Padding" Value="4,3,4,3" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Foreground" Value="#ECECEC" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
        </Style>

        <!-- Buttons: default WPF buttons have a LIGHT chrome background; under the dark theme they inherited the
             light Foreground = light-text-on-light-button (invisible). This explicit template forces a DARK button
             with BRIGHT text in every state (normal/hover/pressed/disabled) so every button is high-contrast. -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="#F5F5F5" />
            <Setter Property="BorderBrush" Value="#5A5A5A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6,12,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3D3D3D" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="#7CE07C" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#4A4A4A" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#1A1A1A" />
                                <Setter Property="Foreground" Value="#888888" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid: column headers and cells defaulted to light backgrounds; force dark bg + bright text, and a
             clearly-coloured selection (dark green + white) instead of the light selection with light text. -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#262626" />
            <Setter Property="Foreground" Value="#F5F5F5" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="8,5,8,5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#ECECEC" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2E5E2E" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                    <Setter Property="BorderBrush" Value="#2E5E2E" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ListBox/items (e.g. opponent picker) default to a WHITE background; force dark + bright text. -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#161616" />
            <Setter Property="Foreground" Value="#ECECEC" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#ECECEC" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!-- ComboBox DROPDOWN items: the open dropdown popup is light by default, so the items rendered light text
             on a light popup = barely visible (the Network selector and every other dropdown). Each item now has an
             explicit dark background + bright text, with a clear green highlight, so every pull-down is readable. -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Foreground" Value="#ECECEC" />
            <Setter Property="Padding" Value="6,4,6,4" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#2E5E2E" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A2A2A" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#ECECEC" />
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2E5E2E" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Menu dropdown items: bright text on a dark menu surface (the default popup left some light-on-light). -->
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="Foreground" Value="#ECECEC" />
        </Style>

        <!-- Checkable controls + labels: keep their text bright on the dark surfaces. -->
        <Style TargetType="CheckBox"><Setter Property="Foreground" Value="#ECECEC" /></Style>
        <Style TargetType="RadioButton"><Setter Property="Foreground" Value="#ECECEC" /></Style>
        <Style TargetType="Label"><Setter Property="Foreground" Value="#ECECEC" /></Style>
    </Application.Resources>
</Application>
